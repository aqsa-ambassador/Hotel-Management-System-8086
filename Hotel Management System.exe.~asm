;================ SALES =================
SALES:

LEA DX,salesmsg
MOV AH,09H
INT 21H

; ROOM COUNT
LEA DX,roomtxt
MOV AH,09H
INT 21H
MOV AX,roomCount

CALL_PRINT_ROOM:
PUSH AX
PUSH BX
PUSH CX
PUSH DX

MOV BX,10
XOR CX,CX

L1:
XOR DX,DX
DIV BX
PUSH DX
INC CX
CMP AX,0
JNE L1

L2:
POP DX
ADD DL,'0'
MOV AH,02H
INT 21H
LOOP L2

POP DX
POP CX
POP BX
POP AX

